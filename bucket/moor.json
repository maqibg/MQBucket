{
    "version": "0.5.6",
    "description": "A modern MCP (Model Context Protocol) manager built with Tauri",
    "homepage": "https://github.com/varandrew/moor",
    "license": "MIT",
    "notes": [
        "Moor is an MCP Manager for managing Model Context Protocol servers",
        "User data: %LOCALAPPDATA%\\com.snowautumn.moor\\",
        "This package persists the data directory via Junction link"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/varandrew/moor/releases/download/v0.5.6/Moor_0.5.6_x64-setup.exe#/dl.7z",
            "hash": "48001f2f34fadf81496097dff4083912c71e03637f2f31e0e6b6121748c4a7db"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": "moor.exe",
    "shortcuts": [
        [
            "moor.exe",
            "Moor"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:LOCALAPPDATA 'com.snowautumn.moor'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"Junction already exists: $source\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"Path exists and is not a directory: $source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"Migration failed, keeping original: $source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"Backed up original: $backup\"",
        "    } catch {",
        "        Write-Host \"Cannot rename original: $source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:LOCALAPPDATA 'com.snowautumn.moor'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/varandrew/moor"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/varandrew/moor/releases/download/v$version/Moor_$version_x64-setup.exe#/dl.7z"
            }
        }
    }
}
