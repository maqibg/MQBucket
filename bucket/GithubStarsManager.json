{
    "version": "0.1.7",
    "description": "An app for managing GitHub starred repositories with AI-powered analysis",
    "homepage": "https://github.com/AmintaCCCP/GithubStarsManager",
    "license": "MIT",
    "notes": [
        "GitHub Stars Manager 是一个管理 GitHub Star 仓库的工具",
        "用户数据由 Scoop 持久化管理",
        "包含: GitHub token、仓库数据、AI配置、WebDAV配置等"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v0.1.7/GitHub.Stars.Manager.Setup.0.1.7.exe#/dl.7z",
            "hash": "7376ceb59e459ed568bc4908c0ceb79d294495ddcd7a516b2e77dee7720958fb"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "GitHub Stars Manager.exe",
    "shortcuts": [
        [
            "GitHub Stars Manager.exe",
            "GitHub Stars Manager"
        ]
    ],
    "persist": [
        [
            "$env:APPDATA\\GitHub Stars Manager",
            "data"
        ]
    ],
    "checkver": {
        "github": "https://github.com/AmintaCCCP/GithubStarsManager"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AmintaCCCP/GithubStarsManager/releases/download/v$version/GitHub.Stars.Manager.Setup.$version.exe#/dl.7z"
            }
        }
    }
}
