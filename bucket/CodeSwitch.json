    "bin": [
        [
            "CodeSwitch.exe",
            "codeswitch"
        ]
    ],
    "shortcuts": [
        [
            "CodeSwitch.exe",
            "Code Switch"
        ]
    ],
    "persist": [
        [
            "$env:USERPROFILE\\.code-switch",
