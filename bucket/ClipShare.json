{
    "version": "1.4.3+25",
    "description": "ClipShare - A cross-platform clipboard sharing tool with cloud sync support",
    "homepage": "https://github.com/aa2013/ClipShare",
    "license": "GPL-3.0-only",
    "notes": [
        "ClipShare 是一个跨平台的剪贴板共享工具",
        "源码表明：Windows 桌面端在程序目录可写时，会把 clipshare.db、files/、logs/、jieba/ 等用户数据直接写到安装目录",
        "源码同时会把备份、更新下载缓存、appIcons 等写到 %USERPROFILE%\\Documents\\ClipShare\\",
        "本包会持久化上述用户数据，但不会接管安装包自带的 current\\data 运行时资源目录"
    ],
    "url": "https://github.com/aa2013/ClipShare/releases/download/v1.4.3/clipshare-1.4.3%2B25-windows-setup.zip",
    "hash": "de49d0479ca08f30f0a7c2e5e1a97d14b921d896f9f2ab8b390d6857d728a88b",
    "bin": "ClipShare.exe",
    "shortcuts": [
        [
            "ClipShare.exe",
            "ClipShare"
        ]
    ],
    "post_install": [
        "$source = Join-Path ([Environment]::GetFolderPath('MyDocuments')) 'ClipShare'",
        "$target = Join-Path $persist_dir 'documents'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": [
        "clipshare.db",
        "files",
        "logs",
        "jieba"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/aa2013/ClipShare/releases/latest",
        "jsonpath": "$..assets[*].name",
        "regex": "clipshare-(?<version>[\\d.]+\\+[\\d]+)-windows-setup\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/aa2013/ClipShare/releases/download/v$matchHead/clipshare-$version-windows-setup.zip"
    }
}
