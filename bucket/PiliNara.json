{
    "version": "2.0.1+4897",
    "description": "A Flutter desktop client derived from PiliPlus with offline cache support",
    "homepage": "https://github.com/Starfallan/PiliNara",
    "license": "GPL-3.0-only",
    "notes": [
        "PiliNara 是基于 PiliPlus 修改的 Flutter 桌面客户端",
        "应用数据目录：%APPDATA%\\com.example\\PiliNara\\",
        "  - hive\\：账号、Cookie、设置、历史与离线缓存元数据",
        "  - download\\：默认离线缓存视频目录",
        "  - flutter_inappwebview\\：桌面端内嵌网页数据",
        "启动器会把 TEMP/TMP 指向 Scoop 的 persist\\temp，用于接管运行期图片/字幕/转码临时文件",
        "首次安装时会预置 setting.hive，将 enableLog 关闭，避免默认把日志写到系统 Documents 根目录",
        "若你在设置中手动修改离线下载目录，后续缓存视频将保存到你指定的位置",
        "图片、截图、字幕与字节导出等显式“另存为”操作使用系统相册或 FilePicker 目标路径，不纳入 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Starfallan/PiliNara/releases/latest/download/PiliNara_windows_2.0.1%2B4897_x64_portable.zip",
            "hash": "bfd0eca6bf176924a22d2cbfd7c2c23d8e3a0e70981cf45645323eb3e641b7d1"
        }
    },
    "pre_install": [
        "$launcherPs1 = @(",
        "    '$ErrorActionPreference = ''Stop''',",
        "    ('$persistDir = ''{0}''' -f $persist_dir),",
        "    ('$appDir = ''{0}''' -f $dir),",
        "    '$tempDir = Join-Path $persistDir ''temp''',",
        "    'New-Item -ItemType Directory -Force -Path $tempDir | Out-Null',",
        "    '$env:TEMP = $tempDir',",
        "    '$env:TMP = $tempDir',",
        "    'Start-Process -FilePath (Join-Path $appDir ''pilinara.exe'') -WorkingDirectory $appDir | Out-Null'",
        ") -join \"`r`n\"",
        "[IO.File]::WriteAllText((Join-Path $dir 'PiliNara-launcher.ps1'), $launcherPs1, [Text.UTF8Encoding]::new($false))",
        "$launcherCmd = @(",
        "    '@echo off',",
        "    'powershell -NoProfile -ExecutionPolicy Bypass -File \"%~dp0PiliNara-launcher.ps1\" %*'",
        ") -join \"`r`n\"",
        "[IO.File]::WriteAllText((Join-Path $dir 'PiliNara.cmd'), $launcherCmd, [Text.UTF8Encoding]::new($false))"
    ],
    "bin": [
        [
            "PiliNara.cmd",
            "PiliNara"
        ]
    ],
    "shortcuts": [
        [
            "PiliNara.cmd",
            "PiliNara"
        ]
    ],
    "post_install": [
        "$ensureJunction = {",
        "    param([string]$Source, [string]$Target)",
        "    ensure $Target",
        "",
        "    if (Test-Path $Source) {",
        "        $item = Get-Item -LiteralPath $Source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$Source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$Source\"",
        "        }",
        "",
        "        & robocopy $Source $Target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$Source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$Source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $Source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$Source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $Source -ItemType Junction -Value $Target | Out-Null",
        "}",
        "",
        "ensure (Join-Path $persist_dir 'data')",
        "ensure (Join-Path $persist_dir 'data\\hive')",
        "ensure (Join-Path $persist_dir 'data\\download')",
        "ensure (Join-Path $persist_dir 'data\\flutter_inappwebview')",
        "ensure (Join-Path $persist_dir 'logs')",
        "ensure (Join-Path $persist_dir 'temp')",
        "",
        "$sourceParent = Join-Path $env:APPDATA 'com.example'",
        "$source = Join-Path $sourceParent 'PiliNara'",
        "ensure $sourceParent",
        "& $ensureJunction $source (Join-Path $persist_dir 'data')",
        "",
        "$docsDir = [Environment]::GetFolderPath('MyDocuments')",
        "$logPath = Join-Path $docsDir '.pili_logs.json'",
        "$logTarget = Join-Path $persist_dir 'logs\\.pili_logs.json'",
        "if (!(Test-Path $logTarget)) { New-Item -Path $logTarget -ItemType File | Out-Null }",
        "",
        "if (Test-Path $logPath) {",
        "    $logItem = Get-Item -LiteralPath $logPath -Force",
        "    if (-not $logItem.PSIsContainer -and -not ($logItem.Attributes -band [IO.FileAttributes]::ReparsePoint) -and -not $logItem.LinkType) {",
        "        if ((Get-Item -LiteralPath $logTarget -Force).Length -eq 0) {",
        "            Move-Item -LiteralPath $logPath -Destination $logTarget -Force",
        "        } else {",
        "            Get-Content -Path $logPath -Encoding UTF8 -Raw | Add-Content -Path $logTarget -Encoding UTF8",
        "            Remove-Item -LiteralPath $logPath -Force",
        "        }",
        "    }",
        "}",
        "",
        "if (!(Test-Path $logPath)) {",
        "    $sameVolume = ([IO.Path]::GetPathRoot($logPath) -eq [IO.Path]::GetPathRoot($logTarget))",
        "    if ($sameVolume) {",
        "        New-Item -Path $logPath -ItemType HardLink -Value $logTarget | Out-Null",
        "    } else {",
        "        try {",
        "            New-Item -Path $logPath -ItemType SymbolicLink -Value $logTarget | Out-Null",
        "        } catch {",
        "            Write-Host \"无法为日志文件创建链接：$logPath -> $logTarget\"",
        "        }",
        "    }",
        "}",
        "",
        "$settingTemplate = 'FQAAAAEJZW5hYmxlTG9nAwDDP4jR'",
        "$settingPath = Join-Path $persist_dir 'data\\hive\\setting.hive'",
        "if (!(Test-Path $settingPath)) {",
        "    [IO.File]::WriteAllBytes($settingPath, [Convert]::FromBase64String($settingTemplate))",
        "}"
    ],
    "post_uninstall": [
        "$appSupport = Join-Path (Join-Path $env:APPDATA 'com.example') 'PiliNara'",
        "if (Test-Path $appSupport) {",
        "    $item = Get-Item -LiteralPath $appSupport -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $appSupport -Force",
        "    }",
        "}",
        "$logPath = Join-Path ([Environment]::GetFolderPath('MyDocuments')) '.pili_logs.json'",
        "if (Test-Path $logPath) {",
        "    $logItem = Get-Item -LiteralPath $logPath -Force",
        "    if (($logItem.Attributes -band [IO.FileAttributes]::ReparsePoint) -or $logItem.LinkType -eq 'HardLink' -or $logItem.LinkType -eq 'SymbolicLink') {",
        "        Remove-Item -LiteralPath $logPath -Force",
        "    }",
        "}"
    ],
    "persist": [
        "data",
        "logs",
        "temp"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/Starfallan/PiliNara/releases/latest",
        "regex": "PiliNara_windows_(?<version>[\\d.]+\\+\\d+)_x64_portable\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Starfallan/PiliNara/releases/latest/download/PiliNara_windows_$version_x64_portable.zip"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
