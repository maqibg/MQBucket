{
    "version": "6.1.80.320",
    "description": "游戏加加轻量版是一款专注于硬件检测与游戏实时监控的轻量工具。",
    "homepage": "https://gamepp.com/download.html",
    "license": {
        "identifier": "Unknown",
        "url": "https://gamepp.com/terms-of-use.html"
    },
    "notes": [
        "官网当前“游戏加加轻量版”按钮指向独立安装包 GamePPLite_Setup.exe，而非完整版下载地址",
        "官网页面顶部当前统一展示版本 V 5.6.51.327，但轻量版当前安装包文件版本为 6.1.80.320；本包以实际交付安装包版本为准",
        "解包可见主程序为 Main\\GamePPLite.exe；common.7z 仅包含 quality 预设与 desk.ico 等随包资源，不作为用户数据持久化",
        "轻量版卸载器字符串明确包含 %LOCALAPPDATA%\\GamePPLite、%APPDATA%\\GamePPLite\\GPPLogs.txt 与 Software\\GamePPLite",
        "轻量版前端脚本会通过 getAppDataDir() 访问 common\\Data 等运行数据，因此本包接管 %LOCALAPPDATA%\\GamePPLite 与 %APPDATA%\\GamePPLite",
        "本包会将这两个目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "url": "https://dllite.gamepp.com/download/GamePPLite_Setup.exe?1775729348#/dl.7z",
    "hash": "3fa49645f4ec58eb494b1c8089e68b0d4af977603fd6203fc28f669657fe80bc",
    "installer": {
        "script": [
            "Move-Item \"$dir\\Main\\*\" \"$dir\" -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\Main\" -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "bin": [
        [
            "GamePPLite.exe",
            "gamepp-lite"
        ]
    ],
    "shortcuts": [
        [
            "GamePPLite.exe",
            "游戏加加轻量版"
        ]
    ],
    "post_install": [
        "$ensureJunction = {",
        "    param($source, $name)",
        "    $target = Join-Path $persist_dir $name",
        "    ensure $target",
        "",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$source\"",
        "        }",
        "",
        "        & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $source -ItemType Junction -Value $target | Out-Null",
        "}",
        "",
        "& $ensureJunction (Join-Path $env:LOCALAPPDATA 'GamePPLite') 'localdata'",
        "& $ensureJunction (Join-Path $env:APPDATA 'GamePPLite') 'roaming'"
    ],
    "post_uninstall": [
        "$sources = @(",
        "    (Join-Path $env:LOCALAPPDATA 'GamePPLite'),",
        "    (Join-Path $env:APPDATA 'GamePPLite')",
        ")",
        "foreach ($source in $sources) {",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Remove-Item -LiteralPath $source -Force",
        "        }",
        "    }",
        "}"
    ],
    "persist": [
        "localdata",
        "roaming"
    ],
    "checkver": {
        "script": [
            "$ErrorActionPreference = 'Stop'",
            "$page = Invoke-WebRequest -Uri 'https://gamepp.com/download.html' -UseBasicParsing",
            "$page.Content -match 'https://dllite\\.gamepp\\.com/download/GamePPLite_Setup\\.exe\\?(?<token>\\d+)' | Out-Null",
            "$token = $Matches['token']",
            "$url = \"https://dllite.gamepp.com/download/GamePPLite_Setup.exe?$token\"",
            "$tmp = Join-Path $env:TEMP ('gamepp-lite-checkver-' + [guid]::NewGuid().ToString('N') + '.exe')",
            "Invoke-WebRequest -Uri $url -OutFile $tmp -UseBasicParsing",
            "$version = (Get-Item $tmp).VersionInfo.FileVersion",
            "Remove-Item $tmp -Force",
            "\"$version|$token\""
        ],
        "regex": "(?<version>[\\d.]+)\\|(?<token>\\d+)"
    },
    "autoupdate": {
        "url": "https://dllite.gamepp.com/download/GamePPLite_Setup.exe?$matchToken#/dl.7z",
        "hash": {
            "mode": "download"
        }
    }
}
