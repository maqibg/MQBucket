{
    "version": "3.9.5",
    "description": "A full-featured download manager — rebuilt from the ground up.",
    "homepage": "https://github.com/AnInsomniacy/motrix-next",
    "license": "MIT",
    "notes": [
        "核心数据目录：%APPDATA%\\com.motrix.next\\",
        "  - config.json / system.json / user.json：偏好设置与 aria2 参数",
        "  - history.db / download.session：任务历史与会话",
        "日志目录：%LOCALAPPDATA%\\com.motrix.next\\logs\\",
        "安装目录内的 binaries\\aria2.conf 与 motrixnext-aria2c.exe 为程序 sidecar，不纳入 persist",
        "个人数据通过 Junction 持久化到 Scoop persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.9.5/MotrixNext_3.9.5_x64-setup.exe#/dl.7z",
            "hash": "761a86351901fddc9740860d718abab60f8da31fc25b54706cde4de7025920aa"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.9.5/MotrixNext_3.9.5_arm64-setup.exe#/dl.7z",
            "hash": "4447d7d6060ab8f2e01f30098026349e42d3e159649c3cde3b7852fe135fae94"
        }
    },
    "pre_install": "Remove-Item -Path \"$dir\\`$*\" -Force -Recurse",
    "bin": [
        [
            "motrix-next.exe",
            "motrix-next"
        ]
    ],
    "shortcuts": [
        [
            "motrix-next.exe",
            "Motrix Next"
        ]
    ],
    "post_install": [
        "$ensureJunction = {",
        "    param([string]$Source, [string]$Target)",
        "    ensure $Target",
        "    $parent = Split-Path $Source -Parent",
        "    if ($parent) {",
        "        New-Item -ItemType Directory -Path $parent -Force | Out-Null",
        "    }",
        "",
        "    if (Test-Path $Source) {",
        "        $item = Get-Item -LiteralPath $Source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$Source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$Source\"",
        "        }",
        "",
        "        & robocopy $Source $Target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$Source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$Source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $Source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$Source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $Source -ItemType Junction -Value $Target | Out-Null",
        "}",
        "",
        "$dataSource = Join-Path $env:APPDATA 'com.motrix.next'",
        "$logsSource = Join-Path (Join-Path $env:LOCALAPPDATA 'com.motrix.next') 'logs'",
        "& $ensureJunction $dataSource (Join-Path $persist_dir 'data')",
        "& $ensureJunction $logsSource (Join-Path $persist_dir 'logs')"
    ],
    "post_uninstall": [
        "$paths = @(",
        "    (Join-Path $env:APPDATA 'com.motrix.next'),",
        "    (Join-Path (Join-Path $env:LOCALAPPDATA 'com.motrix.next') 'logs')",
        ")",
        "foreach ($path in $paths) {",
        "    if (Test-Path $path) {",
        "        $item = Get-Item -LiteralPath $path -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Remove-Item -LiteralPath $path -Force",
        "        }",
        "    }",
        "}"
    ],
    "persist": [
        "data",
        "logs"
    ],
    "checkver": {
        "github": "https://github.com/AnInsomniacy/motrix-next"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe#/dl.7z"
            }
        }
    }
}
